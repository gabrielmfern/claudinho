{
  "name": "claudinho-nvim",
  "version": "0.2.0",
  "description": "Claude Code MCP plugin for Neovim integration",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gabrielmfern/claudinho.git"
  },
  "homepage": "https://github.com/gabrielmfern/claudinho",
  "bugs": {
    "url": "https://github.com/gabrielmfern/claudinho/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": "dist/index.js",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "neovim": "5.4.0",
    "zod": "3.25.76"
  },
  "packageManager": "pnpm@10.32.1",
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@changesets/changelog-github": "0.6.0",
    "@changesets/cli": "2.30.0",
    "@types/node": "25.5.2",
    "tsdown": "0.21.7",
    "tsx": "4.21.0",
    "typescript": "6.0.2"
  }
}
