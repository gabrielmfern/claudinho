{
  "name": "claudinho.nvim",
  "version": "0.1.0",
  "description": "Claude Code MCP plugin for Neovim integration",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "format": "biome format --write src"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "neovim": "5.4.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@types/node": "25.5.2",
    "tsx": "4.21.0",
    "typescript": "6.0.2"
  }
}
